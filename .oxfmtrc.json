{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "all",
	"printWidth": 80,
	"sortTailwindcss": {
		"stylesheet": "./src/app.css"
	},
	"svelte": {},
	"importOrder": [
		"<BUILTIN_MODULES>",
		"",
		"<THIRD_PARTY_MODULES>",
		"",
		"^\\./\\$types",
		"",
		"^\\$(?!lib/)",
		"",
		"^\\$lib/(?!data|components|pages|atoms)",
		"",
		"^\\$lib/atoms(/.*)?$",
		"",
		"^\\$lib/components(/.*)?$",
		"",
		"^\\$lib/pages(/.*)?$",
		"",
		"^\\$lib/data(/.*)?$",
		"",
		"^[.]"
	],
	"sortPackageJson": true,
	"ignorePatterns": [
		".DS_Store",
		"node_modules",
		"/build",
		"/.svelte-kit",
		"/package",
		".env",
		".env.*",
		"!.env.example",
		"pnpm-lock.yaml",
		"package-lock.json",
		"yarn.lock"
	]
}
