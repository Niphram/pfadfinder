{
	"tailwindCSS.experimental.configFile": "src/app.css",
	"tailwindCSS.experimental.classRegex": [
		"\\S*Class={\\s*([\\s\\S]+?)\\s*}",
		"\\S*Class=\"([^\"]+)\"",
		"class:(.+)"
	],

	"files.associations": {
		"*.css": "tailwindcss"
	},

	"oxc.fmt.configPath": ".oxfmtrc.json",
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"editor.formatOnSave": true
}
